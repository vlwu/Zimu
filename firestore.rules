rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Read stories subcollection rules
      match /readStories/{storyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Shared stories collection rules
    match /stories/{storyId} {
      // Allow any authenticated user to read/query stories
      allow read: if request.auth != null;
      // Disallow client-side writes (must occur server-side via firebase-admin)
      allow write: if false;
    }
  }
}